include_once 'tours.features.inc';

/**
 * Update the tours_get_tour_types function if modifying the tour types.
 */
define ('TOURS_SINGLE_DAY', 'single_day_tour');
define ('TOURS_SINGLE_DAY_SLOT', 'single_day_tour_slot');
define ('TOURS_PRIVATE_SINGLE_DAY_SLOT', 'private_single_day_tour_slot');
define ('TOURS_MULTI_DAY', 'multi_day_tour');

define ('ROOMS_PART_BOOKED', 4);


/**
 * Drupal hooks.
 */

/**
 * Implements hook_menu().
 */
function tours_menu() {
  $items['tours_availability_reference/autocomplete/%/%/%'] = array(
    'page callback' => 'tours_availability_reference_autocomplete',
    'page arguments' => array(2, 3, 4),
    'access arguments' => array('reference booking unit availability'),
    'type' => MENU_CALLBACK,
  );
  return $items;
}

/**
 * Implements hook_theme().
 */
function tours_theme() {
  return array(
    'tours_availability_field_calendar' => array(
      'render element' => 'tours_availability_field_calendar',
      'template' => 'tours_availability_field_calendar',
    ),
    'tours_availability_single_day' => array(
      'render element' => 'tours_availability_single_day',
      'template' => 'tours_availability_single_day',
    ),
  );
}

/**
 * hook_entity_presave().
 */
function tours_entity_presave($entity, $type) {
  if ($type == 'rooms_unit') {
    if ($entity->type == TOURS_SINGLE_DAY) {
      // Single-Day Tour Slot
      if (isset($entity->field_daily_slot[LANGUAGE_NONE])) {
        foreach ($entity->field_daily_slot[LANGUAGE_NONE] as $slot_id) {
          $slot = rooms_unit_load($slot_id['target_id']);

          // Base price of the Single-Day Tour Slot is the same as the Single-Day Tour.
          $slot->base_price = $entity->base_price;

          // The Title of the Single-Day Tour Slot is the same Title as the Single-Day Tour Bookable Unit
          // it is associated with + the start and end time of the tour.
          if ($slot->name == '') {
            $time_format = array(
              'separator' => ':',
              'period_separator' => '',
              'period' => 'a',
              'hour' => 'g',
              'minute' => 'i'
            );

            $start_time = timefield_integer_to_time($time_format, $slot->field_day_tour_time_slot[LANGUAGE_NONE][0]['value']);

            $end_time = timefield_integer_to_time($time_format, $slot->field_day_tour_time_slot[LANGUAGE_NONE][0]['value2']);

            $slot->name = $entity->name . ' (' . $start_time . ' - ' . $end_time . ')';
          }

          rooms_unit_save($slot);
        }
      }

      // Private Single-Day Tour Slot
      if (isset($entity->field_private_daily_slot[LANGUAGE_NONE])) {
        foreach ($entity->field_private_daily_slot[LANGUAGE_NONE] as $slot_id) {
          $slot = rooms_unit_load($slot_id['target_id']);

          // Base price of the Single-Day Tour Slot is the same as the Single-Day Tour.
          $slot->base_price = $entity->base_price;

          // The Title of the Single-Day Tour Slot is the same Title as the Single-Day Tour Bookable Unit
          // it is associated with + the start and end time of the tour.
          if ($slot->name == '') {
            $time_format = array(
              'separator' => ':',
              'period_separator' => '',
              'period' => 'a',
              'hour' => 'g',
              'minute' => 'i'
            );

            $start_time = timefield_integer_to_time($time_format, $slot->field_day_tour_time_slot[LANGUAGE_NONE][0]['value']);

            $end_time = timefield_integer_to_time($time_format, $slot->field_day_tour_time_slot[LANGUAGE_NONE][0]['value2']);

            $slot->name = $entity->name . ' (' . $start_time . ' - ' . $end_time . ') - Private tour';
          }

          rooms_unit_save($slot);
        }
      }
    }
    elseif ($entity->type == TOURS_SINGLE_DAY_SLOT || $entity->type == TOURS_PRIVATE_SINGLE_DAY_SLOT) {
      $entity->default_state = ROOMS_NOT_AVAILABLE;
    }
  }
}

