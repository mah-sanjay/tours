}

/**
 * Implements hook_field_widget_form().
 */
function tours_field_widget_form(&$form, &$form_state, $field, $instance, $langcode, $items, $delta, $element) {
  switch ($instance['widget']['type']) {
    case 'tours_availability_reference_autocomplete':
      $element += array(
        '#type' => 'textfield',
        '#default_value' => isset($items[$delta]['unit_id']) ? $items[$delta]['unit_id'] : NULL,
        '#autocomplete_path' => $instance['widget']['settings']['autocomplete_path'] . '/' . $instance['entity_type'] . '/' . $instance['bundle'] . '/' . $field['field_name'],
        '#size' => $instance['widget']['settings']['size'],
        '#maxlength' => 255,
        '#element_validate' => array('tours_availability_reference_autocomplete_validate'),
        '#value_callback' => 'tours_availability_reference_autocomplete_value',
      );
      break;
  }
  return array('unit_id' => $element);
}

/**
 * Implements hook_field_formatter_settings_form().
 */
function tours_field_formatter_settings_form($field, $instance, $view_mode, $form, &$form_state) {
  $display = $instance['display'][$view_mode];
  $settings = $display['settings'];

  if ($instance['display'][$view_mode]['type'] == 'tours_multiday_availability_reference_default') {
    $element['book_now'] = array(
      '#title' => t('Display "Book now"'),
      '#type' => 'checkbox',
      '#default_value' => $settings['book_now'],
    );
  }

  $element['enquire_about'] = array(
    '#title' => t('Display "Enquire about this Tour"'),
    '#type' => 'checkbox',
    '#default_value' => $settings['enquire_about'],
  );

  if ($instance['display'][$view_mode]['type'] == 'tours_singleday_availability_reference_default') {
    $element['display_calendar'] = array(
      '#title' => t('Display as calendar'),
      '#type' => 'checkbox',
      '#default_value' => $settings['display_calendar'],
    );
  }

  return $element;
}

/**
 * Implements hook_field_formatter_settings_summary().
 */
function tours_field_formatter_settings_summary($field, $instance, $view_mode) {
  $display = $instance['display'][$view_mode];
  $settings = $display['settings'];

  $summary = array();
  
  if ($instance['display'][$view_mode]['type'] == 'tours_multiday_availability_reference_default') {
    $summary[] = ($settings['book_now']) ? 'Display "Book now"' : 'Don\'t display "Book now"';
  }
  $summary[] = ($settings['enquire_about']) ? 'Display "Enquire about this Tour"' : 'Don\'t display "Enquire about this Tour"';
  if ($instance['display'][$view_mode]['type'] == 'tours_singleday_availability_reference_default') {
    $summary[] = ($settings['display_calendar']) ? 'Display as calendar' : 'Don\'t display as calendar';
  }

  return implode('<br />', $summary);
}

/**
 * Implements hook_field_widget_error().
 */
function tours_field_widget_error($element, $error, $form, &$form_state) {
  form_error($element['unit_id'], $error['message']);
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * FORM_ID = rooms_availability_event_manager_form
 */
function tours_form_rooms_availability_event_manager_form_alter(&$form, $form_state) {
  $unit = rooms_unit_load($form['unit_id']['#value']);
  $tour_types = tours_get_tour_types(TRUE);

  if (in_array($unit->type, $tour_types)) {
    if (isset($form['order'])) {
      unset($form['order']);

      $form['submit'] = array(
        '#type' => 'submit',
        '#value' => 'Create Tour',
        '#submit' => array('tours_add_tour_instance'),
      );

      if ($form_state['submitted']) {
        $commands[] = ctools_modal_command_dismiss();

        print ajax_render($commands);
        exit;
      }
    }
  }
  else {
    // This is not a tours unit, hide the tours booking link.
    if (isset($form['order']['order_link']['tour_instance'])) {
      unset($form['order']['order_link']['tour_instance']);
    }
  }
}

function tours_add_tour_instance($form, &$form_state) {
  global $user;

  // Add the tour instance bookings.
  $unit = rooms_unit_load($form_state['values']['unit_id']);

  if ($unit->type == TOURS_SINGLE_DAY_SLOT || $unit->type == TOURS_PRIVATE_SINGLE_DAY_SLOT) {
    $start_date = $form_state['values']['rooms_start_date'];
    $end_date = $form_state['values']['rooms_end_date'];
    $end_date = $end_date->modify('+1 day');

    $interval = new DateInterval('P1D');
    $period = new DatePeriod($start_date, $interval, $end_date);

    foreach ($period as $dt) {
      // Ensure we don't have a conflicting booking.
      $rc = new UnitCalendar($unit->unit_id);
      $states = $rc->getStates($dt, $dt);
      // Taking the most conservative approach for now.
      foreach ($states as $state) {
        if ($state != ROOMS_AVAILABLE) {
          drupal_set_message(t('Could not add booking for event with start date of @start and end date of @end, there was an availability conflict!',
                         array('@start' => $instance['value'], '@end' => $instance['value2'])), 'warning');
          continue;
        }
      }

      $profile = tours_get_default_customer_profile();

      $params = array(
        'unit_id' => $unit->unit_id,
        'unit_type' => $unit->type,
        'uid' => $user->uid,
        'customer_id' => $profile->uid,
        'name' => $profile->commerce_customer_address[LANGUAGE_NONE][0]['name_line'],
        'type' => 'tour_instance',
        'created' => time(),
        'changed' => time(),
        'language' => LANGUAGE_NONE,
        'start_date' => $dt->format('Y-m-d'),
        'end_date' => $dt->format('Y-m-d'),
        'data' => array('group_size' => $unit->max_sleeps),
        'price' => $unit->base_price * 100,
      );
      $booking = rooms_booking_create($params);
      rooms_booking_save($booking);
    }
  }
  else {
    $start_date = $form_state['values']['rooms_start_date'];
    $end_date = $form_state['values']['rooms_end_date'];

    // Ensure we don't have a conflicting booking.
    $rc = new UnitCalendar($unit->unit_id);
    $states = $rc->getStates($start_date, $end_date);
    // Taking the most conservative approach for now.
    foreach ($states as $state) {
      if ($state != ROOMS_AVAILABLE) {
        drupal_set_message(t('Could not add booking for event with start date of @start and end date of @end, there was an availability conflict!',
                       array('@start' => $instance['value'], '@end' => $instance['value2'])), 'warning');
        return;
      }
    }

    $profile = tours_get_default_customer_profile();

    $params = array(
      'unit_id' => $unit->unit_id,
      'unit_type' => $unit->type,
      'uid' => $user->uid,
      'customer_id' => $profile->uid,
      'name' => $profile->commerce_customer_address[LANGUAGE_NONE][0]['name_line'],
      'type' => 'tour_instance',
      'created' => time(),
      'changed' => time(),
      'language' => LANGUAGE_NONE,
      'start_date' => $start_date->format('Y-m-d'),
      'end_date' => $end_date->format('Y-m-d'),
      'data' => array('group_size' => $unit->max_sleeps),
      'price' => $unit->base_price * 100,
    );
    $booking = rooms_booking_create($params);
    rooms_booking_save($booking);
  }

  $form_state['rebuild'] = TRUE;
}

