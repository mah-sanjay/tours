/**
 * Implements hook_commerce_checkout_complete().
 */
function tours_commerce_checkout_complete($order) {
  foreach ($order->commerce_line_items as $lang => $item) {
    foreach ($item as $item_id) {
      $line_item = commerce_line_item_load($item_id['line_item_id']);
      if ($line_item->type == 'tours_booking') {
        $booking = rooms_booking_load($line_item->tours_booking_reference[LANGUAGE_NONE][0]['target_id']);

        $already_added = FALSE;
        if (isset($booking->field_tour_orders[LANGUAGE_NONE])) {
          foreach ($booking->field_tour_orders[LANGUAGE_NONE] as $order_id) {
            if ($order_id['target_id'] == $order->order_id) {
              $already_added = TRUE;
            }
          }
        }

        if (!$already_added) {
          $booking->field_tour_orders[LANGUAGE_NONE][]['target_id'] = $order->order_id;

          if (tours_booking_free_quantity($booking) <= 0) {
            $booking->booking_status = 1;
          }

          rooms_booking_save($booking);
        }

        // Set booking to confirmed if minimum occupancy has been reached.
        /*if (isset($line_item->tours_booked_unit_id)) {
          $unit = rooms_unit_load($line_item->tours_booked_unit_id[LANGUAGE_NONE][0]['value']);
          if (tours_booking_quantity_booked($booking) >= $unit->min_sleeps) {
            $booking->booking_status = 1;
            rooms_booking_save($booking);
          }
        }*/
      }
    }
  }
}


/**
 * Rooms hooks.
 */

/**
 * Implements hook_rooms_availability_update().
 */
function tours_rooms_availability_update($response, $events) {
  foreach ($response as $event_id => $code) {
    if ($code == ROOMS_UPDATED) {
      foreach ($events as $event) {
        if ($event->id == $event_id) {
          $unit = rooms_unit_load($event->unit_id);
          if ($unit->type == TOURS_SINGLE_DAY_SLOT || $unit->type == TOURS_PRIVATE_SINGLE_DAY_SLOT) {
            $unit_id = $unit->field_day_tour[LANGUAGE_NONE][0]['target_id'];

            $start_date = $event->start_date;
            $end_date = $event->end_date;

            if ($event_id < 0) {
              $event = new BookingEvent($unit_id, ROOMS_PART_BOOKED, $start_date, $end_date);
              $uc = new UnitCalendar($unit_id);
              $responses = $uc->updateCalendar(array($event));
            }
            else {
              $event = new BookingEvent($unit_id, ROOMS_AVAILABLE, $start_date, $end_date);
              $uc = new UnitCalendar($unit_id);
              $responses = $uc->updateCalendar(array($event));
            }
          }
        }
      }
    }
  }
}

/**
 * Implements hook_rooms_price_modifier_alter().
 */
function tours_rooms_price_modifier_alter(&$price_modifiers, $booking_info) {
  $tour_types = tours_get_tour_types();

  // If this is a tour, modify the pricing to be per user, for the entire
  // booking period.
  if (in_array($booking_info['unit']->type, $tour_types)) {
    $length = $booking_info['end_date']->diff($booking_info['start_date']);
    $days = $length->days;
    if ($days > 1) {
      // If the tour is more than 1 day long, adjust the
      // total price to the base price.
      $price_modifiers['total'] = array(
        '#type' => ROOMS_DYNAMIC_MODIFIER,
        '#op_type' => ROOMS_SUB,
        '#amount' => $booking_info['unit']->base_price,
        '#quantity' => ($days - 1),
      );
    }

    // Figure out the group size.
    if (isset($booking_info['booking_parameters']['group_size'])) {
      $group_size = $booking_info['booking_parameters']['group_size'];
    }
    elseif (isset($booking_info['booking_parameters'][0]['adults'])) {
      $group_size = $booking_info['booking_parameters'][0]['adults'];
    }
    else {
      $group_size = $booking_info['booking_parameters']['adults'];
    }

    // Add the base price for each additional person.
    if ($group_size > 1) {
      $amount_per_additional_person = $booking_info['unit']->base_price;
      $price_modifiers['additional'] = array(
        '#type' => ROOMS_DYNAMIC_MODIFIER,
        '#op_type' => ROOMS_ADD,
        '#amount' => $amount_per_additional_person,
        '#quantity' => ($group_size - 1),
      );
    }
  }
}


/**
 * Custom functions.
 */


/**
 * Set a default customer if not already present.
 */
function tours_get_default_customer_profile() {
  // Look for a customer profile for the site admin.
  $profile_id = db_select('commerce_customer_profile', 'cc')
    ->fields('cc', array('profile_id'))
    ->condition('uid', 1)
    ->range(0,1)
    ->execute()
    ->fetchField();
  if ($profile_id) {
    $profile = commerce_customer_profile_load($profile_id);
  }
  else {
    // If there's not one already existing, create it.
    $profile = commerce_customer_profile_new($type = 'billing', $uid = 1);
    $profile->status = '1';
    $profile->commerce_customer_address[LANGUAGE_NONE][0]['country'] = 'US';
    $profile->commerce_customer_address[LANGUAGE_NONE][0]['administrative_area'] = 'NM';
    $profile->commerce_customer_address[LANGUAGE_NONE][0]['postal_code'] = '87501';
    $profile->commerce_customer_address[LANGUAGE_NONE][0]['locality'] = 'Santa Fe';
    $profile->commerce_customer_address[LANGUAGE_NONE][0]['thoroughfare'] = '804 Don Gaspar';
    $profile->commerce_customer_address[LANGUAGE_NONE][0]['name_line'] = 'Tours Owner';
    commerce_customer_profile_save($profile);
  }
  return($profile);
}

/**
 *
 */
function tours_set_tour_dates($entity) {
  $start_date = null;
  $end_date = null;

  // Check whether start and end dates are set.
  if (isset($entity->field_tour_dates[LANGUAGE_NONE][0]['value'])) {
    $start_date = new DateTime($entity->field_tour_dates[LANGUAGE_NONE][0]['value']);
    $end_date = new DateTime($entity->field_tour_dates[LANGUAGE_NONE][0]['value2']);
  }

  if (!isset($start_date)) {
    drupal_set_message(t('Tour dates have not been set'));
    return FALSE;
  } else {
    $tour_event = new BookingEvent($entity->unit_id, ROOMS_AVAILABLE, $start_date, $end_date);

    $events = array($tour_event);
    $ac = new UnitCalendar($entity->unit_id);
    $ac->updateCalendar($events);
  }

  return TRUE;
}

/**
 * Tour availability callback page
 *
 * @param \RoomsUnit $rooms_unit
 * @param string $year
 * @param string $month
 * @return array
 */
function tours_availability_page(RoomsUnit $rooms_unit, $year = '', $month = '') {
  if (in_array($rooms_unit->type, tours_get_tour_types(TRUE))) {
    // Set the page title.
    drupal_set_title(t('Edit @unit_name Tour Dates', array('@unit_name' => $rooms_unit->name)));

    // Add styles.
    rooms_availability_modal_style();

    // Get the current page's URL, striped of the year and month args.
    // This allows us to place this page anywhere, including at
    // unit/%/availability  or  admin/rooms/units/unit/%/availability
    list($url) = explode('/' . $year . '/' . $month, current_path());

    $js_file = drupal_get_path('module', 'rooms_availability') . '/js/rooms_availability.js';
    $css_file = drupal_get_path('module', 'rooms_availability') . '/css/rooms_availability.css';
    // Show full day events on calendar.
    if (variable_get('rooms_calendar_events_view', '0') == '1') {
      $js_file = drupal_get_path('module', 'rooms_availability') . '/js/rooms_availability_full_day.js';
    }
    return array(
      '#theme' => 'rooms_three_month_calendar',
      '#url' => $url,
      '#form' => drupal_get_form('update_availability_calendar_form', $rooms_unit->unit_id, $year, $month),
      '#year' => $year,
      '#month' => $month,
      '#attached' => array(
        'css' => array(
          $css_file,
        ),
        'js' => array(
          $js_file,
          array(
            'data' => array('roomsAvailability' => array('roomID' => $rooms_unit->unit_id)),
            'type' => 'setting',
          ),
        ),
      ),
    );

  }
  else {
    return rooms_availability_page($rooms_unit, $year, $month);
  }
}

/**
 * Return all tour types.
 * @param boolean $all
 */
function tours_get_tour_types($all = FALSE) {
  // Typically we are interested in the multi_day + single day tours, not the single day slots
  if ($all) {
    return array(TOURS_MULTI_DAY, TOURS_SINGLE_DAY, TOURS_SINGLE_DAY_SLOT, TOURS_PRIVATE_SINGLE_DAY_SLOT);
  } else {
    return array(TOURS_MULTI_DAY, TOURS_SINGLE_DAY);
  }
}

/**
 * Menu callback for the autocomplete results.
 */
function tours_availability_reference_autocomplete($entity_type, $bundle, $field_name, $string = '') {
  $field = field_info_field($field_name);
  $instance = field_info_instance($entity_type, $field_name, $bundle);

  $options = array(
    'string' => $string,
    'match' => $instance['widget']['settings']['autocomplete_match'],
    'limit' => 10,
  );
  $references = tours_availability_reference_potential_references($field, $options);

  $matches = array();
  foreach ($references as $id => $row) {
    // Markup is fine in autocompletion results (might happen when rendered
    // through Views) but we want to remove hyperlinks.
    $suggestion = preg_replace('/<a href="([^<]*)">([^<]*)<\/a>/', '$2', $row['rendered']);
    // Add a class wrapper for a few required CSS overrides.
    $matches[$row['title'] . " [unit_id:$id]"] = '<div class="reference-autocomplete">' . $suggestion . '</div>';
  }

  drupal_json_output($matches);
}

/**
 * Retrieves an array of candidate referenceable booking units.
 *
 * This info is used in various places (allowed values, autocomplete
 * results, input validation...). Some of them only need the nids,
 * others nid + titles, others yet nid + titles + rendered row (for
 * display in widgets).
 *
 * The array we return contains all the potentially needed information,
 * and lets consumers use the parts they actually need.
 *
 * @param array $field
 *   The field definition.
 * @param array $options
 *   An array of options to limit the scope of the returned list. The following
 *   key/value pairs are accepted:
 *   - string: string to filter unit names on (used by autocomplete).
 *   - match: operator to match the above string against, can be any of:
 *     'contains', 'equals', 'starts_with'. Defaults to 'contains'.
 *   - ids: array of specific unit ids to lookup.
 *   - limit: maximum size of the the result set. Defaults to 0 (no limit).
 *
 * @return array
 *   An array of valid units in the form:
 *   array(
 *     unit_id => array(
 *       'name' => The unit title,
 *       'rendered' => The text to display in widgets (can be HTML)
 *     ),
 *     ...
 *   )
 */
function tours_availability_reference_potential_references($field, $options = array()) {
  // Fill in default options.
  $options += array(
    'string' => '',
    'match' => 'contains',
    'ids' => array(),
    'limit' => 0,
  );

  $results = &drupal_static(__FUNCTION__, array());

  // Create unique id for static cache.
  $cid = $field['field_name'] . ':' . $options['match'] . ':'
    . ($options['string'] !== '' ? $options['string'] : implode('-', $options['ids']))
    . ':' . $options['limit'];
  if (!isset($results[$cid])) {
    $references = FALSE;

    if ($references === FALSE) {
      $references = _tours_availability_reference_potential_references($field, $options);
    }

    // Store the results.
    $results[$cid] = !empty($references) ? $references : array();
  }

  return $results[$cid];
}

/**
 * Helper function for node_reference_potential_references().
 *
 * List of referenceable nodes defined by content types.
 */
function _tours_availability_reference_potential_references($field, $options) {
  // Avoid useless work.
  if (!isset($field['settings']['referenceable_unit_types'])) {
    return array();
  }

  if (!count($field['settings']['referenceable_unit_types'])) {
    return array();
  }

  $query = db_select('rooms_units', 'u');
  $unit_unit_id_alias = $query->addField('u', 'unit_id');
  $unit_name_alias = $query->addField('u', 'name', 'name');
  $unit_type_alias = $query->addField('u', 'type', 'type');

  if (is_array($field['settings']['referenceable_unit_types'])) {
    $query->condition('u.type', $field['settings']['referenceable_unit_types'], 'IN');
  }

  if ($options['string'] !== '') {
    switch ($options['match']) {
      case 'contains':
        $query->condition('u.name', '%' . $options['string'] . '%', 'LIKE');
        break;

      case 'starts_with':
        $query->condition('u.name', $options['string'] . '%', 'LIKE');
        break;

      case 'equals':
      default:
        // No match type or incorrect match type: use "=".
        $query->condition('u.name', $options['string']);
        break;
    }
  }

  if ($options['ids']) {
    $query->condition('u.unit_id', $options['ids'], 'IN');
  }

  if ($options['limit']) {
    $query->range(0, $options['limit']);
  }

  $query
    ->orderBy($unit_name_alias)
    ->orderBy($unit_type_alias);

  $result = $query->execute()->fetchAll();
  $references = array();
  foreach ($result as $unit) {
    $references[$unit->unit_id] = array(
      'title'    => $unit->name,
      'rendered' => check_plain($unit->name),
    );
  }
  return $references;
}

/**
 * Helper function - return number of slots booked for a tour
 * instance.
 */
function tours_booking_quantity_booked($booking) {
  $unit = rooms_unit_load($booking->unit_id);

  $quantity_booked = 0;

  if (isset($booking->field_tour_orders[LANGUAGE_NONE])) {
    foreach ($booking->field_tour_orders[LANGUAGE_NONE] as $order_id) {
      $order = commerce_order_load($order_id['target_id']);

      if ($order !== FALSE) {
        foreach ($order->commerce_line_items as $lang => $item) {
          foreach ($item as $item_id) {
            $line_item = commerce_line_item_load($item_id['line_item_id']);
            $quantity_booked += $line_item->tours_booking_number_people[LANGUAGE_NONE][0]['value'];
          }
        }
      }
    }
  }

  return $quantity_booked;
}

/**
 * Helper function - return number of booking slots available for a tour
 * instance.
 */
function tours_booking_free_quantity($booking) {
  $unit = rooms_unit_load($booking->unit_id);

  $free_quantity = $unit->max_sleeps;

  if (isset($booking->field_tour_orders[LANGUAGE_NONE])) {
    foreach ($booking->field_tour_orders[LANGUAGE_NONE] as $order_id) {
      $order = commerce_order_load($order_id['target_id']);

      if ($order !== FALSE) {
        foreach ($order->commerce_line_items as $lang => $item) {
          foreach ($item as $item_id) {
            $line_item = commerce_line_item_load($item_id['line_item_id']);

            $free_quantity -= $line_item->tours_booking_number_people[LANGUAGE_NONE][0]['value'];
          }
        }
      }
    }
  }

  return $free_quantity;
}

/**
 * Implements hook_forms().
 *
 * Allows the book now form to be repeated multiple times on a page.
 * See https://api.drupal.org/comment/48318
 */
function tours_forms($form_id, $args) {
  $forms = array();
  if (strncmp($form_id, 'tours_book_now_form_', 20) === 0) {
    $forms[$form_id] = array('callback' => 'tours_book_now_form');
  }

  return $forms;
}

function tours_single_day_book_form($form, &$form_state, $tour) {
  if (isset($form_state['triggering_element'])) {
    if ($form_state['triggering_element']['#name'] == 'date') {
      $form_state['values']['time'] = '_none';
      $form_state['input']['time'] = '_none';

      $form_state['values']['participants'] = '_none';
      $form_state['input']['participants'] = '_none';
    }
    elseif ($form_state['triggering_element']['#name'] == 'time') {
      $form_state['values']['participants'] = '_none';
      $form_state['input']['participants'] = '_none';
    }
  }

  $form['tour'] = array(
    '#type' => 'hidden',
    '#value' => $tour->unit_id,
  );

  $form['date'] = array(
    '#title' => t('Select a date'),
    '#type' => 'date_popup',
    '#flavour' => 'inline',
    '#date_format' => 'Y-m-d',
    '#datepicker_options' => array('minDate' => '+1d', 'maxDate' => '+1y'),
    '#restrictions' => array(
      'allowed_values' => array(
        'type' => 'tours',
        'tour_id' => $tour->unit_id,
      ),
    ),
    '#ajax' => array(
      'wrapper' => 'single-day-tour-container',
      'callback' => 'tours_single_day_ajax_callback',
    ),
  );

  $form['container'] = array(
    '#type' => 'container',
    '#prefix' => '<div id="single-day-tour-container">',
    '#suffix' => '</div>',
  );

  $time_options = array('_none' => t('select time'));
  $form['container']['time'] = array(
    '#type' => 'select',
    '#options' => $time_options,
    '#disabled' => TRUE,
    '#default_value' => isset($form_state['values']['time']) ? $form_state['values']['time'] : '_none',
    '#ajax' => array(
      'wrapper' => 'single-day-tour-container',
      'callback' => 'tours_single_day_ajax_callback',
    ),
  );

  if (isset($form_state['values']['date']) &&
      $form_state['values']['date'] != '' && $form_state['values']['date'] != '_none') {
    $form['container']['time']['#disabled'] = FALSE;

    // Single-Day Tour Slot
    $single_day_tour_slots = array();
    foreach ($tour->field_daily_slot[LANGUAGE_NONE] as $slot) {
      $single_day_tour_slots[] = $slot['target_id'];
    }

    $results = db_select('rooms_bookings', 'b')
                ->fields('b', array('unit_id'))
                ->condition('booking_status', '0')
                ->condition('unit_id', $single_day_tour_slots)
                ->condition('start_date', $form_state['values']['date'])
                ->execute()
                ->fetchAll();

    $available_slots = array();
    foreach ($results as $result) {
      $available_slots[] = $result->unit_id;
    }

    foreach ($tour->field_daily_slot[LANGUAGE_NONE] as $id => $slot) {
      $daily_slot = rooms_unit_load($slot['target_id']);

      if (in_array($daily_slot->unit_id, $available_slots)) {
        $time_options[$daily_slot->unit_id] = $daily_slot->field_day_tour_time_slot[LANGUAGE_NONE][0]['value_formatted'] . ' - ' . $daily_slot->field_day_tour_time_slot[LANGUAGE_NONE][0]['value2_formatted'];
      }
    }

    // Private Single-Day Tour Slot
    $single_day_private_tour_slots = array();
    foreach ($tour->field_private_daily_slot[LANGUAGE_NONE] as $slot) {
      $single_day_private_tour_slots[] = $slot['target_id'];
    }

    $results = db_select('rooms_bookings', 'b')
                ->fields('b', array('unit_id'))
                ->condition('booking_status', '0')
                ->condition('unit_id', $single_day_private_tour_slots)
                ->condition('start_date', $form_state['values']['date'])
                ->execute()
                ->fetchAll();

    $available_slots = array();
    foreach ($results as $result) {
      $available_slots[] = $result->unit_id;
    }

    foreach ($tour->field_private_daily_slot[LANGUAGE_NONE] as $id => $slot) {
      $daily_slot = rooms_unit_load($slot['target_id']);

      if (in_array($daily_slot->unit_id, $available_slots)) {
        $time_options[$daily_slot->unit_id] = $daily_slot->field_day_tour_time_slot[LANGUAGE_NONE][0]['value_formatted'] . ' - ' . $daily_slot->field_day_tour_time_slot[LANGUAGE_NONE][0]['value2_formatted'] . ' - Private Tour';
      }
    }

    $form['container']['time']['#options'] = $time_options;
  }

  $participants_options = array('_none' => t('number of participants'));
  $form['container']['participants'] = array(
    '#type' => 'select',
    '#options' => $participants_options,
    '#disabled' => TRUE,
    '#default_value' => isset($form_state['values']['participants']) ? $form_state['values']['participants'] : '_none',
    '#ajax' => array(
      'wrapper' => 'single-day-tour-container',
      'callback' => 'tours_single_day_ajax_callback',
    ),
  );

  if (isset($form_state['values']['time']) &&
      $form_state['values']['time'] != '' && $form_state['values']['time'] != '_none') {
    $form['container']['participants']['#disabled'] = FALSE;

    $booking_id = db_select('rooms_bookings', 'b')
                  ->fields('b', array('booking_id'))
                  ->condition('booking_status', '0')
                  ->condition('unit_id', $form_state['values']['time'])
                  ->condition('start_date', $form_state['values']['date'])
                  ->execute()
                  ->fetchField();

    $booking = rooms_booking_load($booking_id);

    $participants = tours_booking_free_quantity($booking);

    $participants_options = array_merge($participants_options, range(1, $participants));

    $form['container']['participants']['#options'] = $participants_options;
  }

  $form['container']['price'] = array(
    '#type' => 'markup',
    '#markup' => '<div></div>',
  );

  $form['container']['submit'] = array(
    '#type' => 'submit',
    '#value' => t('Book Now'),
    '#disabled' => TRUE,
  );

  if (isset($form_state['values']['participants']) &&
      $form_state['values']['participants'] != '' && $form_state['values']['participants'] != '_none') {
    $form['container']['submit']['#disabled'] = FALSE;

    $currency_setting = commerce_currency_load(commerce_default_currency());
    $currency_symbol = $currency_setting['symbol'];

    $daily_slot = rooms_unit_load($form_state['values']['time']);

    if ($daily_slot->type == TOURS_PRIVATE_SINGLE_DAY_SLOT) {
      $temp_price = '';
      $max_price = '';
      $max_people = 0;
      $diff = PHP_INT_MAX;

      $participants = $form_state['values']['participants'] + 1;

      if (isset($daily_slot->field_variable_pricing['und'])) {
        foreach ($daily_slot->field_variable_pricing['und'] as $pricing) {
          if ($participants <= $pricing['first']) {
            if (($pricing['first'] - $participants) < $diff) {
              $diff = $pricing['first'] - $participants;
              $temp_price = $pricing['second'];
            }
          }

          if ($max_people < $pricing['first']) {
            $max_people = $pricing['first'];
            $max_price = $pricing['second'];
          }
        }
      }

      if ($temp_price) {
        $price = t('@currency_symbol @amount', array(
          '@currency_symbol' => $currency_symbol,
          '@amount' => number_format($temp_price, 2, '.', ''),
        ));
      }
      elseif ($max_price) {
        $price = t('@currency_symbol @amount', array(
          '@currency_symbol' => $currency_symbol,
          '@amount' => number_format($max_price, 2, '.', ''),
        ));
      }
      else {
        $price = t('@currency_symbol @amount', array(
          '@currency_symbol' => $currency_symbol,
          '@amount' => number_format($daily_slot->base_price * ($form_state['values']['participants'] + 1), 2, '.', ''),
        ));
      }
    }
    else {
      $price = t('@currency_symbol @amount', array(
        '@currency_symbol' => $currency_symbol,
        '@amount' => number_format($daily_slot->base_price * ($form_state['values']['participants'] + 1), 2, '.', ''),
      ));
    }

    $form['container']['price']['#markup'] = '<div class="form-item form-group">' . t('Price') . ': ' . $price . '</div>';
  }

  return $form;
}

function tours_single_day_ajax_callback($form, &$form_state) {
  return $form['container'];
}

function tours_single_day_book_form_submit($form, &$form_state) {
  global $user;
  module_load_include('inc', 'tours', 'tours.commerce');

  $order = commerce_cart_order_load($user->uid);
  if (empty($order)) {
    $order = commerce_order_new($user->uid, 'pending');
  }

  $values = $form_state['values'];

  $tour = rooms_unit_load($values['tour']);
  $date = $values['date'];
  $daily_slot = rooms_unit_load($values['time']);
  $participants = $values['participants'] + 1;

  $booking_id = db_select('rooms_bookings', 'b')
                  ->fields('b', array('booking_id'))
                  ->condition('booking_status', '0')
                  ->condition('unit_id', $values['time'])
                  ->condition('start_date', $values['date'])
                  ->execute()
                  ->fetchField();

  $booking_parameters = array('adults' => $participants, 'children' => 0);
  $agent = new AvailabilityAgent(new DateTime($date), new DateTime($date), $booking_parameters);
  $price_modifiers = array();

  $unit = array(
    'unit' => $daily_slot,
    'state' => ROOMS_AVAILABLE,
  );

  $line_item = tours_create_line_item($unit, $agent, $booking_parameters, $price_modifiers);

  $line_item->tours_booking_reference[LANGUAGE_NONE][0]['target_id'] = $booking_id;

  // Add line item to cart.
  $line_item = commerce_cart_product_add($user->uid, $line_item, FALSE);

  // Refresh line items price and redirect to bookings page.
  commerce_cart_order_refresh(commerce_cart_order_load($user->uid));

  $form_state['redirect'] = 'bookings';
}

function tours_book_now_form($form, &$form_state, $booking) {
  $free_quantity = tours_booking_free_quantity($booking);

  if ($free_quantity > 0) {
    $form['booking_id'] = array(
      '#type' => 'hidden',
      '#value' => $booking->booking_id,
    );

    $form['group_size'] = array(
      '#title' => t('Quantity'),
      '#type' => 'select',
      '#options' => range(1, $free_quantity),
    );

    $form['submit'] = array(
      '#type' => 'submit',
      '#value' => t('Book Now'),
    );
  }

  return $form;
}

function tours_book_now_form_submit($form, &$form_state) {
  global $user;
  module_load_include('inc', 'tours', 'tours.commerce');

  $order = commerce_cart_order_load($user->uid);
  if (empty($order)) {
    $order = commerce_order_new($user->uid, 'pending');
  }

  $booking_id = $form_state['values']['booking_id'];
  $group_size = $form_state['values']['group_size'] + 1;

  $booking = rooms_booking_load($booking_id);

  $unit = array(
    'unit' => rooms_unit_load($booking->unit_id),
    'state' => ROOMS_AVAILABLE,
  );

  $sd = $booking->start_date_object;
  $ed = $booking->end_date_object;

  $booking_parameters = array('adults' => 1, 'children' => 0);

  $agent = new AvailabilityAgent($sd, $ed, $booking_parameters);

  $price_modifiers = array();

  for ($i = 0; $i < $group_size; $i++) {
    $line_item = tours_create_line_item($unit, $agent, $booking_parameters, $price_modifiers);

    $line_item->tours_booking_reference[LANGUAGE_NONE][0]['target_id'] = $booking->booking_id;

    // Add line item to cart.
    $line_item = commerce_cart_product_add($user->uid, $line_item, FALSE);
  }

  // Refresh line items price and redirect to bookings page.
  commerce_cart_order_refresh(commerce_cart_order_load($user->uid));

  $form_state['redirect'] = 'bookings';
}

/**
 * Calculates the price for rooms_booking line item types.
 *
 * @param object $line_item
 *   Line item to modify.
 */
function tours_price_apply($line_item) {
  if ($line_item->type == 'tours_booking') {
    if ($item = field_get_items('commerce_line_item', $line_item, 'commerce_product')) {
      $product = commerce_product_load($item[0]['product_id']);
      if ($product->sku != 'ROOMS-BASIC-BOOKING') {
        return;
      }
    }
    $amount = $line_item->commerce_unit_price[LANGUAGE_NONE][0]['amount'];

    $start_date = new DateTime($line_item->tours_booking_dates[LANGUAGE_NONE][0]['value']);
    $end_date = new DateTime($line_item->tours_booking_dates[LANGUAGE_NONE][0]['value2']);

    $unit_id = $line_item->tours_booked_unit_id[LANGUAGE_NONE][0]['value'];
    $unit = rooms_unit_load($unit_id);

    // First set up price modifiers.
    $price_options = is_array(field_get_items('commerce_line_item', $line_item, 'rooms_booking_options')) ? field_get_items('commerce_line_item', $line_item, 'rooms_booking_options') : array();

    // Convert Price options in Price modifiers.
    foreach ($price_options as $option) {
      $price_modifiers[strtolower(str_replace(array(':', ' '), '_', $option['name']))] = array(
        '#name' => $option['name'],
        '#type' => ROOMS_DYNAMIC_MODIFIER,
        '#op_type' => $option['operation'],
        '#amount' => $option['value'],
        '#quantity' => $option['quantity'],
      );
    }

    $adults = $line_item->tours_booking_number_people[LANGUAGE_NONE][0]['value'];
    $children = $line_item->tours_booking_number_people[LANGUAGE_NONE][1]['value'];
    $childrens_age = (isset($line_item->tours_booking_children_ages[LANGUAGE_NONE])) ?
                      $line_item->tours_booking_children_ages[LANGUAGE_NONE] : array();

    $booking_info = array(
      'start_date' => clone($start_date),
      'end_date' => clone($end_date),
      'unit' => $unit,
      'booking_parameters' => array(
        'group_size' => $adults,
        'group_size_children' => $children,
        'childrens_age' => $childrens_age,
      ),
    );

    // Give other modules a chance to change the price modifiers.
    drupal_alter('rooms_price_modifier', $price_modifiers, $booking_info);

    $price_calendar = new UnitPricingCalendar($unit->unit_id, $price_modifiers);

    $temp_end_date = clone($end_date);
    $temp_end_date->sub(new DateInterval('P1D'));

    $price = $price_calendar->calculatePrice($start_date, $temp_end_date, $adults, $children, $childrens_age);

    $full_price = $price['full_price'] * 100;

    $line_item->commerce_unit_price[LANGUAGE_NONE][0]['amount'] = $full_price;
    $line_item->commerce_unit_price[LANGUAGE_NONE][0]['currency_code'] = commerce_default_currency();

    foreach ($line_item->commerce_unit_price[LANGUAGE_NONE][0]['data']['components'] as $key => $component) {
      $line_item->commerce_unit_price[LANGUAGE_NONE][0]['data']['components'][$key]['price']['amount'] = $full_price / $amount * $component['price']['amount'];
    }
  }
}

/**
 * Value callback for a tours_availability_reference autocomplete element.
 *
 * Replace the unit id with a unit name.
 */
function tours_availability_reference_autocomplete_value($element, $input = FALSE, $form_state) {
  if ($input === FALSE) {
    // We're building the displayed 'default value': expand the raw unit id into
    // "unit name [unit_id:n]".
    $unit_id = $element['#default_value'];
    if (!empty($unit_id)) {
      $unit = rooms_unit_load($unit_id);
      $value = $unit->name;
      $value .= ' [unit_id:' . $unit_id . ']';
      return $value;
    }
  }
}

/**
 * Validation callback for a node_reference autocomplete element.
 */
function tours_availability_reference_autocomplete_validate($element, &$form_state, $form) {
  $field = field_widget_field($element, $form_state);
  $instance = field_widget_instance($element, $form_state);

  $value = $element['#value'];
  $unit_id = NULL;

  if (!empty($value)) {
    // Check whether we have an explicit "[unit_id:n]" input.
    preg_match('/^(?:\s*|(.*) )?\[\s*unit_id\s*:\s*(\d+)\s*\]$/', $value, $matches);
    if (!empty($matches)) {
      // Explicit nid. Check that the 'title' part matches the actual title for
      // the nid.
      list(, $title, $unit_id) = $matches;
      if (!empty($title)) {
        $unit = rooms_unit_load($unit_id);
        $real_title = $unit->name;
        if (trim($title) != trim($real_title)) {
          form_error($element, t('%name: title mismatch. Please check your selection.', array('%name' => $instance['label'])));
        }
      }
    }
    else {
      // No explicit unit_id (the submitted value was not populated by
      // autocomplete selection). Get the unit_id of a referenceable node from
      // the entered title.
      $options = array(
        'string' => $value,
        'match' => 'equals',
        'limit' => 1,
      );
      $references = tours_availability_reference_potential_references($field, $options);
      if ($references) {
        // @todo The best thing would be to present the user with an
        // additional form, allowing the user to choose between valid
        // candidates with the same title. ATM, we pick the first
        // matching candidate...
        $unit_id = key($references);
      }
      else {
        form_error($element, t('%name: unable to find a unit with that title.', array('%name' => $instance['label'])));
      }
    }
  }

  // Set the element's value as the node id that was extracted from the entered
  // input.
  form_set_value($element, $unit_id, $form_state);
}

/**
 * Implements hook_field_widget_form_alter().
 */
function tours_field_widget_form_alter(&$element, &$form_state, $context) {
  if (isset($element['#field_name'])) {
    if ($element['#field_name'] == 'field_daily_slot' || $element['#field_name'] == 'field_private_daily_slot') {
      $ief_id = $element['#ief_id'];

      foreach ($element['entities'] as $key => $value) {
        if (is_numeric($key)) {
          if (isset($value['#entity']->unit_id) && !empty($value['#entity']->unit_id)) {
            $element['entities'][$key]['actions']['manage_availability'] = array(
              '#type' => 'submit',
              '#value' => t('Manage availability'),
              '#name' => 'ief-' . $ief_id . '-manage-availability-' . $key,
              '#limit_validation_errors' => array(),
              '#submit' => array('tours_single_day_slot_manage_availability'),
              '#ief_row_delta' => $key,
              '#unit_id' => $value['#entity']->unit_id,
            );
          }
        }
      }
    }
  }
}

function tours_single_day_slot_manage_availability($form, &$form_state) {
  $unit_id = $form_state['triggering_element']['#unit_id'];

  $form_state['redirect'] = 'admin/rooms/units/unit/' . $unit_id . '/availability';
}

/**
 * Implements hook_menu_local_tasks_alter().
 */
function tours_menu_local_tasks_alter(&$data, $router_item, $root_path) {
  if ($root_path == 'admin/rooms/units/unit/%/availability' || $root_path == 'admin/rooms/units/unit/%/pricing') {
    if (isset($router_item['page_arguments'][0]->type)) {
      if ($router_item['page_arguments'][0]->type == TOURS_SINGLE_DAY_SLOT) {
        $tour_slot = rooms_unit_load(arg(4));
        $day_tour = $tour_slot->field_day_tour['und'][0]['target_id'];

        if (rooms_unit_access('update', rooms_unit_load($day_tour))) {
          // Add a 'Back to Tour' tab that links back to the parent single day tour edit page.
          $data['tabs'][0]['output'][0]['#link']['title'] = t('Back to Tour');
          $data['tabs'][0]['output'][0]['#link']['href'] = 'admin/rooms/units/unit/' . $day_tour . '/edit';
        }
        else {
          unset($data['tabs'][0]['output'][0]);
        }

        if ($data['tabs'][0]['output'][1]['#link']['path'] == 'admin/rooms/units/unit/%/edit') {
          // Remove 'edit' tab.
          unset($data['tabs'][0]['output'][1]);
        }
      }
    }
  }
}

/**
 * Implements hook_rooms_booking_amount_before_modifiers_alter().
 */
function tours_rooms_booking_amount_before_modifiers_alter(&$price, $booking_info) {
  $unit = $booking_info['unit'];

  if ($unit->type == TOURS_PRIVATE_SINGLE_DAY_SLOT) {
    $adults = $booking_info['booking_parameters']['group_size'];

    $temp_price = '';
    $max_price = '';
    $max_people = 0;
    $diff = PHP_INT_MAX;

    if (isset($unit->field_variable_pricing['und'])) {
      foreach ($unit->field_variable_pricing['und'] as $pricing) {
        if ($adults <= $pricing['first']) {
          if (($pricing['first'] - $adults) < $diff) {
            $diff = $pricing['first'] - $adults;
            $temp_price = $pricing['second'];
          }
        }

        if ($max_people < $pricing['first']) {
          $max_people = $pricing['first'];
          $max_price = $pricing['second'];
        }
      }
    }

    if ($temp_price) {
      $price = $temp_price;
    }
    elseif ($max_price) {
      $price = $max_price;
    }
  }
}
