          '#date_flexible' => 0,
          '#date_repeat_collapsed' => TRUE,
        ),
      ),
    );
  }
}

/**
 * Validation for tour instance repeating date add form.
 */
function tours_add_instances_form_submit($form, &$form_state) {
  global $user;

  // Set up variables.
  $rrule = $form_state['values']['parent1']['parent2']['rrule'];
  $rrule_values = date_ical_parse_rrule(NULL, $rrule);
  $timezone = date_default_timezone();
  $format = 'Y-m-d H:i';
  $start_date = $form_state['values']['date'];
  $end_date = $form_state['values']['end_date'];

  // Calculate the event duration.
  $start = new DateObject($start_date, $timezone, $format);
  $end = new DateObject($end_date, $timezone, $format);
  $duration = $start->difference($end);

  // Figure out when to stop.
  $start_datetime = date_format($start, DATE_FORMAT_DATETIME);
  if (!empty($rrule_values['UNTIL']['datetime'])) {
    $end = date_ical_date($rrule_values['UNTIL'], $timezone);
    $end_datetime = date_format($end, DATE_FORMAT_DATETIME);
  }
  elseif (!empty($rrule_values['COUNT'])) {
    $end_datetime = NULL;
  }

  // Split the RRULE into RRULE, EXDATE, and RDATE parts.
  $parts = date_repeat_split_rrule($rrule);
  $parsed_exceptions = (array) $parts[1];
  $exceptions = array();
  foreach ($parsed_exceptions as $exception) {
    $date = date_ical_date($exception, $timezone);
    $exceptions[] = date_format($date, 'Y-m-d');
  }

  $parsed_rdates = (array) $parts[2];
  $additions = array();
  foreach ($parsed_rdates as $rdate) {
    $date = date_ical_date($rdate, $timezone);
    $additions[] = date_format($date, 'Y-m-d');
  }

  // Calculate the dates for bookings we want to add.
  $dates = date_repeat_calc($rrule, $start_datetime, $end_datetime, $exceptions, $timezone, $additions);
  $value = array();
  foreach ($dates as $delta => $date) {
    // date_repeat_calc always returns DATE_DATETIME dates, which is
    // not necessarily $field['type'] dates.
    // Convert returned dates back to db timezone before storing.
    $date_start = new DateObject($date, $timezone, DATE_FORMAT_DATETIME);
    $date_end = clone($date_start);
    date_modify($date_end, '+' . $duration . ' seconds');
    $value[$delta] = array(
      'value' => date_format($date_start, $format),
      'value2' => date_format($date_end, $format),
      'offset' => date_offset_get($date_start),
      'offset2' => date_offset_get($date_end),
      'timezone' => $timezone,
      'rrule' => $rrule,
      );
  }

  // Add the tour instance bookings.
  $unit = rooms_unit_load($form_state['values']['unit_id']);
  foreach ($value as $instance) {
    $profile = tours_get_default_customer_profile();

    $params = array(
      'unit_id' => $unit->unit_id,
      'unit_type' => $unit->type,
      'uid' => $user->uid,
      'customer_id' => $profile->uid,
      'name' => $profile->commerce_customer_address[LANGUAGE_NONE][0]['name_line'],
      'type' => 'tour_instance',
      'created' => time(),
      'changed' => time(),
      'language' => LANGUAGE_NONE,
      'start_date' => $instance['value'],
      'end_date' => $instance['value2'],
      'data' => array('group_size' => 0),
    );
    $booking = rooms_booking_create($params);
    rooms_booking_save($booking);
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Modifications to tour booking form.
 */
function tours_form_rooms_booking_edit_form_alter(&$form, &$form_state) {
  if ($form['#bundle'] == 'tour_instance') {
    // Allow single day bookings.
    $form_state['single_day_bookings'] = TRUE;

    // Hide 'children' selection.
    $form['data']['group_size_children']['#access'] = FALSE;
    $form['data']['group_size_children']['#access'] = FALSE;

    $profile = tours_get_default_customer_profile();
    $form['client']['#default_value'] = $profile->commerce_customer_address[LANGUAGE_NONE][0]['name_line'] . ':' . $profile->profile_id;
  }
}

