      'description' => t('Display the list of referenceable units as a textfield with autocomplete behaviour.'),
      'field types' => array('tours_availability_reference'),
      'settings'    => array(
        'autocomplete_match' => 'contains',
        'size' => 60,
        'autocomplete_path' => 'tours_availability_reference/autocomplete',
      ),
    ),
  );
}

/**
 * Implements hook_field_widget_form().
 */
function tours_field_widget_form(&$form, &$form_state, $field, $instance, $langcode, $items, $delta, $element) {
  switch ($instance['widget']['type']) {
    case 'tours_availability_reference_autocomplete':
      $element += array(
        '#type' => 'textfield',
        '#default_value' => isset($items[$delta]['unit_id']) ? $items[$delta]['unit_id'] : NULL,
        '#autocomplete_path' => $instance['widget']['settings']['autocomplete_path'] . '/' . $instance['entity_type'] . '/' . $instance['bundle'] . '/' . $field['field_name'],
        '#size' => $instance['widget']['settings']['size'],
        '#maxlength' => 255,
        '#element_validate' => array('tours_availability_reference_autocomplete_validate'),
        '#value_callback' => 'tours_availability_reference_autocomplete_value',
      );
      break;
  }
  return array('unit_id' => $element);
}

/**
 * Implements hook_field_formatter_settings_form().
 */
function tours_field_formatter_settings_form($field, $instance, $view_mode, $form, &$form_state) {
  $display = $instance['display'][$view_mode];
  $settings = $display['settings'];

  $element['book_now'] = array(
    '#title' => t('Display "Book now"'),
    '#type' => 'checkbox',
    '#default_value' => $settings['book_now'],
  );

  $element['enquire_about'] = array(
    '#title' => t('Display "Enquire about this Tour"'),
    '#type' => 'checkbox',
    '#default_value' => $settings['enquire_about'],
  );

  return $element;
}

/**
 * Implements hook_field_formatter_settings_summary().
 */
function tours_field_formatter_settings_summary($field, $instance, $view_mode) {
  $display = $instance['display'][$view_mode];
  $settings = $display['settings'];

  $summary = array();

  $summary[] = ($settings['book_now']) ? 'Display "Book now"' : 'Don\'t display "Book now"';
  $summary[] = ($settings['enquire_about']) ? 'Display "Enquire about this Tour"' : 'Don\'t display "Enquire about this Tour"';

  return implode('<br />', $summary);
}

/**
 * Value callback for a tours_availability_reference autocomplete element.
 *
 * Replace the unit id with a unit name.
 */
function tours_availability_reference_autocomplete_value($element, $input = FALSE, $form_state) {
  if ($input === FALSE) {
    // We're building the displayed 'default value': expand the raw unit id into
    // "unit name [unit_id:n]".
    $unit_id = $element['#default_value'];
    if (!empty($unit_id)) {
      $unit = rooms_unit_load($unit_id);
      $value = $unit->name;
      $value .= ' [unit_id:' . $unit_id . ']';
      return $value;
    }
  }
}

/**
 * Validation callback for a node_reference autocomplete element.
 */
function tours_availability_reference_autocomplete_validate($element, &$form_state, $form) {
  $field = field_widget_field($element, $form_state);
  $instance = field_widget_instance($element, $form_state);

  $value = $element['#value'];
  $unit_id = NULL;

  if (!empty($value)) {
    // Check whether we have an explicit "[unit_id:n]" input.
    preg_match('/^(?:\s*|(.*) )?\[\s*unit_id\s*:\s*(\d+)\s*\]$/', $value, $matches);
    if (!empty($matches)) {
      // Explicit nid. Check that the 'title' part matches the actual title for
      // the nid.
      list(, $title, $unit_id) = $matches;
      if (!empty($title)) {
        $unit = rooms_unit_load($unit_id);
        $real_title = $unit->name;
        if (trim($title) != trim($real_title)) {
          form_error($element, t('%name: title mismatch. Please check your selection.', array('%name' => $instance['label'])));
        }
      }
    }
    else {
      // No explicit unit_id (the submitted value was not populated by
      // autocomplete selection). Get the unit_id of a referenceable node from
      // the entered title.
      $options = array(
        'string' => $value,
        'match' => 'equals',
        'limit' => 1,
      );
      $references = tours_availability_reference_potential_references($field, $options);
      if ($references) {
        // @todo The best thing would be to present the user with an
        // additional form, allowing the user to choose between valid
        // candidates with the same title. ATM, we pick the first
        // matching candidate...
        $unit_id = key($references);
      }
      else {
        form_error($element, t('%name: unable to find a unit with that title.', array('%name' => $instance['label'])));
      }
    }
  }

  // Set the element's value as the node id that was extracted from the entered
  // input.
  form_set_value($element, $unit_id, $form_state);
}

/**
 * Implements hook_field_widget_error().
 */
function tours_field_widget_error($element, $error, $form, &$form_state) {
  form_error($element['unit_id'], $error['message']);
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * FORM_ID = rooms_unit_type_form
 */
function tours_form_rooms_unit_type_form_alter(&$form, &$form_state, $form_id) {
  $unit_type = $form_state['rooms_unit_type'];
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * FORM_ID = rooms_unit_edit_form_alter
 */
function tours_form_rooms_unit_edit_form_alter(&$form, &$form_state, $form_id){
  $tour_types = tours_get_tour_types();

  if (in_array($form['#entity']->type, $tour_types)) {
    // Change Unit Name to Tour Name.
    $form['name']['#title'] = t('Tour Name');

    // Base price represents the default price for the tour.
    $form['base_price']['#title'] = t('Tour Standard Price');

    // Guest capacity is going to stand in for Tour Capacity
    $form['guest_capacity']['#title'] = t('Tour Capacity');
    $form['guest_capacity']['max_sleeps']['#description'] =
      t('The total number of people that can participate in the tour. The minimum
       number represents the minimum amount required for the tour to take place');

    // Hide chidren and bed arrangement stuff.
    unset($form['data']['bed_arrangement']);
    unset($form['child_capacity']);
  }
}

/**
 * Implements hook_form_FORMID_alter().
 *
 * Override the availability form to make sense for tours.
 */
