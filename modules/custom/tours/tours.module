/**
 * Implements hook_menu().
 */
function tours_menu() {
  $items['tours_availability_reference/autocomplete/%/%/%'] = array(
    'page callback' => 'tours_availability_reference_autocomplete',
    'page arguments' => array(2, 3, 4),
    'access arguments' => array('reference booking unit availability'),
    'type' => MENU_CALLBACK,
  );
  return $items;
}

