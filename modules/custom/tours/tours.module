include_once 'tours.features.inc';

/**
 * Update the tours_get_tour_types function if modifying the tour types.
 */
define ('TOURS_SINGLE_DAY', 'single_day_tour');
define ('TOURS_SINGLE_DAY_SLOT', 'single_day_tour_slot');
define ('TOURS_MULTI_DAY', 'multi_day_tour');


/**
 * Drupal hooks.
 */

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * FORM_ID = rooms_unit_type_form
 */
function tours_form_rooms_unit_type_form_alter(&$form, &$form_state, $form_id) {
  $unit_type = $form_state['rooms_unit_type'];
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * FORM_ID = rooms_unit_edit_form_alter
 */
function tours_form_rooms_unit_edit_form_alter(&$form, &$form_state, $form_id){
  $tour_types = tours_get_tour_types();

  if (in_array($form['#entity']->type, $tour_types)) {
    // Change Unit Name to Tour Name.
    $form['name']['#title'] = t('Tour Name');

    // Base price represents the default price for the tour.
    $form['base_price']['#title'] = t('Tour Standard Price');

    // Guest capacity is going to stand in for Tour Capacity
    $form['guest_capacity']['#title'] = t('Tour Capacity');
    $form['guest_capacity']['max_sleeps']['#description'] =
      t('The total number of people that can participate in the tour. The minimum
       number represents the minimum amount required for the tour to take place');

    // Hide chidren and bed arrangement stuff.
    unset($form['data']['bed_arrangement']);
    unset($form['child_capacity']);
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Modifications to tour booking form.
 */
function tours_form_rooms_booking_edit_form_alter(&$form, &$form_state) {
  if ($form['#bundle'] == 'tour_instance') {
    // Hide 'children' selection.
    $form['data']['group_size_children']['#access'] = FALSE;

    // Set a default customer if not already present.
    //
    // Look for a customer profile for the site admin.
    $profile_id = db_select('commerce_customer_profile', 'cc')
      ->fields('cc', array('profile_id'))
      ->condition('uid', 1)
      ->range(0,1)
      ->execute()
      ->fetchField();
    if ($profile_id) {
      $profile = commerce_customer_profile_load($profile_id);
    }
    else {
      // If there's not one already existing, create it.
      $profile = commerce_customer_profile_new($type = 'billing', $uid = 1);
      $profile->status = '1';
      $profile->commerce_customer_address[LANGUAGE_NONE][0]['country'] = 'US';
      $profile->commerce_customer_address[LANGUAGE_NONE][0]['administrative_area'] = 'NM';
      $profile->commerce_customer_address[LANGUAGE_NONE][0]['postal_code'] = '87501';
      $profile->commerce_customer_address[LANGUAGE_NONE][0]['locality'] = 'Santa Fe';
      $profile->commerce_customer_address[LANGUAGE_NONE][0]['thoroughfare'] = '804 Don Gaspar';
      $profile->commerce_customer_address[LANGUAGE_NONE][0]['name_line'] = 'Tours Owner';
      commerce_customer_profile_save($profile);
    }
    $form['client']['#default_value'] = $profile->commerce_customer_address[LANGUAGE_NONE][0]['name_line'] . ':' . $profile->profile_id;
  }
}

/**
 * Implements hook_menu_alter().
 */
function tours_menu_alter(&$items) {
  $items['admin/rooms/units/unit/%rooms_unit/availability']['page callback'] = 'tours_availability_page';
}

function tours_entity_info_alter(&$entity_info) {
  $entity_info['rooms_unit']['inline entity form'] = array(
    'controller' => 'RoomsUnitInlineEntityFormController',
  );
}

