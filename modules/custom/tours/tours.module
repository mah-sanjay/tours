/**
 * Implements hook_field_formatter_prepare_view().
 */
function tours_field_formatter_prepare_view($entity_type, $entities, $field, $instances, $langcode, &$items, $displays) {
  if ($field['type'] == 'entityreference') {
    entityreference_field_formatter_prepare_view($entity_type, $entities, $field, $instances, $langcode, $items, $displays);
  }
}

/**
 * Implements hook_field_formatter_view().
 *
 * @todo parametrize date range
 */
function tours_field_formatter_view($entity_type, $entity, $field, $instance, $langcode, $items, $display) {

  $booking_ids = array();
  $element = array();

  switch ($display['type']) {
    case 'tours_availability_reference_default':

      $unit_names = array();
      $unit_ids = array();
      foreach ($items as $delta => $item) {
        if ($field['type'] == 'entityreference') {
          if (empty($item['access'])) {
            continue;
          }
          $unit = ($item['entity']);
        }
        else {
          $unit = rooms_unit_load($item['unit_id']);
        }

        if ($unit) {
          $unit_names[] = $unit->name;
          $unit_ids[] = $unit->unit_id;
        }
      }

      foreach ($unit_ids as $unit_id) {
        $booking_ids = rooms_booking_ids(array('unit_id' => $unit_id));
      }

    break;
  }

  if (!empty($booking_ids)) {
    $results = array();

    $bookings = rooms_booking_load_multiple(array_keys($booking_ids), array('type' => 'tour_instance'));

    $currency_setting = commerce_currency_load(commerce_default_currency());
    $currency_symbol = $currency_setting['symbol'];

    foreach ($bookings as $booking) {
      $results[] = array(
        'id' => $booking->booking_id,
        'start_date' => $booking->start_date_object->format('Y-m-d'),
        'end_date' => $booking->end_date_object->format('Y-m-d'),
        'price' => t('@currency_symbol @amount', array('@currency_symbol' => $currency_symbol, '@amount' => number_format($booking->price / 100, 2, '.', ''))),
        'book_now' => drupal_get_form('tours_book_now_form', $booking),
        'settings' => $display['settings'],
      );
    }

    if (!empty($results)) {
      $element[] = array(
        '#theme' => 'tours_availability_field_calendar',
        'bookings' => $results,
      );
    }
  }

  return $element;
}

/**
 * Implements hook_field_settings_form().
 */
function tours_field_settings_form($field, $instance, $has_data) {
  $settings = $field['settings'];

  $form = array();
  $form['referenceable_unit_types'] = array(
    '#type' => 'checkboxes',
    '#title' => t('Unit types that can be referenced'),
    '#multiple' => TRUE,
    '#default_value' => isset($settings['referenceable_unit_types']) ? $settings['referenceable_unit_types'] : array(),
    '#options' => array_map('check_plain', rooms_unit_types_ids()),
  );

  return $form;

}

/**
 * Implements hook_field_validate().
 */
function tours_field_validate($entity_type, $entity, $field, $instance, $langcode, $items, &$errors) {
  // Extract unit ids to check.
  $ids = array();

  // Check for non-numeric values.
  // First check non-numeric "nid's to avoid losing time with them.
  foreach ($items as $delta => $item) {
    if (is_array($item) && !empty($item['unit_id'])) {
      if (is_numeric($item['unit_id'])) {
        $ids[] = $item['unit_id'];
      }
      else {
        $errors[$field['field_name']][$langcode][$delta][] = array(
          'error' => 'invalid_unit_id',
          'message' => t('%name: invalid input.',
            array('%name' => $instance['label'])),
        );
      }
    }
  }
}

/**
 * Implements hook_field_widget_info().
 */
function tours_field_widget_info() {
  return array(
    'tours_availability_reference_autocomplete' => array(
